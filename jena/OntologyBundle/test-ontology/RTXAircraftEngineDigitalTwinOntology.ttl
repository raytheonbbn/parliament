                obo:BFO_0000004
                [
                  a owl:Class ;
                  owl:complementOf obo:BFO_0000006 ;
                ]
              ) ;
          ]
        ) ;
    ] ;
  rdfs:label "participates in at all times"@en ;
  rdfs:range obo:BFO_0000015 ;
  rdfs:subPropertyOf obo:BFO_0000056 ;
  skos:definition "b participates in p at all times =Def for all times t, b exists at t implies (p has participant b at t)"@en ;
  skos:prefLabel "participates in at all times"@en ;
.
obo:BFO_0000167
  a owl:ObjectProperty ;
  dc:identifier "249-BFO" ;
  rdfs:domain obo:BFO_0000015 ;
  rdfs:label "has participant at all times"@en ;
  rdfs:range [
      a owl:Class ;
      owl:unionOf (
          obo:BFO_0000020
          obo:BFO_0000031
          [
            a owl:Class ;
            owl:intersectionOf (
                obo:BFO_0000004
                [
                  a owl:Class ;
                  owl:complementOf obo:BFO_0000006 ;
                ]
              ) ;
          ]
        ) ;
    ] ;
  rdfs:subPropertyOf obo:BFO_0000057 ;
  skos:definition "p has participant c at all times =Def for all times t, p exists at t implies (p is a process, c is a continuant, and c participates in p some way at t)"@en ;
  skos:prefLabel "has participant at all times"@en ;
.
obo:BFO_0000170
  a owl:ObjectProperty ;
  dc:identifier "237-BFO" ;
  rdfs:domain [
      a owl:Class ;
      owl:intersectionOf (
          obo:BFO_0000004
          [
            a owl:Class ;
            owl:complementOf obo:BFO_0000006 ;
          ]
        ) ;
    ] ;
  rdfs:label "location of at all times"@en ;
  rdfs:range [
      a owl:Class ;
      owl:intersectionOf (
          obo:BFO_0000004
          [
            a owl:Class ;
            owl:complementOf obo:BFO_0000006 ;
          ]
        ) ;
    ] ;
  rdfs:subPropertyOf obo:BFO_0000124 ;
  skos:definition "b location of c at all times =Def for all times t, b exists at t implies (c located in b at t)"@en ;
  skos:prefLabel "location of at all times"@en ;
.
obo:BFO_0000171
  a owl:ObjectProperty ;
  dc:identifier "234-BFO" ;
  rdfs:domain [
      a owl:Class ;
      owl:intersectionOf (
          obo:BFO_0000004
          [
            a owl:Class ;
            owl:complementOf obo:BFO_0000006 ;
          ]
        ) ;
    ] ;
  rdfs:label "located in at some time"@en ;
  rdfs:range [
      a owl:Class ;
      owl:intersectionOf (
          obo:BFO_0000004
          [
            a owl:Class ;
            owl:complementOf obo:BFO_0000006 ;
          ]
        ) ;
    ] ;
  skos:definition "b located in c at some time =Def for some time t (b and c are independent continuants and not spatial regions, and the spatial region which b occupies at t is a (proper or improper) continuant part of the spatial region which c occupies at t)"@en ;
  skos:prefLabel "located in at some time"@en ;
.
obo:BFO_0000172
  a owl:ObjectProperty ;
  dc:identifier "231-BFO" ;
  rdfs:domain obo:BFO_0000040 ;
  rdfs:label "has member part at all times"@en ;
  rdfs:range obo:BFO_0000040 ;
  rdfs:subPropertyOf obo:BFO_0000110 ;
  rdfs:subPropertyOf obo:BFO_0000115 ;
  skos:definition "b has member part c at all times =Def for all times t, b exists at t implies (c member part b at t)"@en ;
  skos:prefLabel "has member part at all times"@en ;
.
obo:BFO_0000173
  a owl:ObjectProperty ;
  dc:identifier "229-BFO" ;
  rdfs:domain obo:BFO_0000040 ;
  rdfs:label "member part of at all times"@en ;
  rdfs:range obo:BFO_0000040 ;
  rdfs:subPropertyOf obo:BFO_0000129 ;
  rdfs:subPropertyOf obo:BFO_0000177 ;
  skos:definition "b member part of c at all times =Def for all times t, b exists at t implies (b is an object & c is an object aggregate & there is at t a mutually exhaustive and pairwise disjoint partition of c into objects x1,..., xn (for some n ≠ 1) with b = xi (for some 1 <= i <= n))"@en ;
  skos:prefLabel "member part of at all times"@en ;
.
obo:BFO_0000174
  a owl:ObjectProperty ;
  dc:identifier "226-BFO" ;
  rdfs:domain obo:BFO_0000002 ;
  rdfs:label "has proper continuant part at some time"@en ;
  rdfs:range obo:BFO_0000002 ;
  rdfs:subPropertyOf obo:BFO_0000178 ;
  owl:inverseOf obo:BFO_0000175 ;
  skos:definition "b has proper continuant part c at some time =Def c proper continuant part of b at some time"@en ;
  skos:prefLabel "has proper continuant part at some time"@en ;
.
obo:BFO_0000175
  a owl:ObjectProperty ;
  dc:identifier "224-BFO" ;
  rdfs:domain obo:BFO_0000002 ;
  rdfs:label "proper continuant part of at some time"@en ;
  rdfs:range obo:BFO_0000002 ;
  rdfs:subPropertyOf obo:BFO_0000176 ;
  skos:definition "b proper continuant part of c at some time =Def for some time t (b continuant part of c at t & not (c continuant part of b at t)"@en ;
  skos:prefLabel "proper continuant part of at some time"@en ;
.
obo:BFO_0000176
  a owl:ObjectProperty ;
  dc:identifier "221-BFO" ;
  rdfs:domain obo:BFO_0000002 ;
  rdfs:label "continuant part of at some time"@en ;
  rdfs:label "continuant part of"@en ;
  rdfs:range obo:BFO_0000002 ;
  owl:inverseOf obo:BFO_0000178 ;
  skos:definition "b continuant part of c =Def b and c are continuants & there is some time t such that b and c exist at t & b continuant part of c at t"@en ;
  skos:definition "b continuant part of c at some time =Def for some time t (b exists at t and c exists at t and b continuant part of c at t & t is a temporal region & b and c are continuants)"@en ;
  skos:example "Milk teeth continuant part of human at some time; surgically removed tumour continuant part of organism at some time."@en ;
  skos:example "Milk teeth continuant part of human; surgically removed tumour continuant part of organism"@en ;
  skos:prefLabel "continuant part of at some time"@en ;
  skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <https://github.com/BFO-ontology/BFO-2020/tree/master/src/owl/profiles/temporal%20extensions>"@en ;
.
obo:BFO_0000177
  a owl:ObjectProperty ;
  a owl:TransitiveProperty ;
  dc:identifier "222-BFO" ;
  rdfs:domain obo:BFO_0000002 ;
  rdfs:label "continuant part of at all times"@en ;
  rdfs:range obo:BFO_0000002 ;
  rdfs:subPropertyOf obo:BFO_0000176 ;
  skos:definition "b continuant part of c at all times =Def for all times t, (b exists at t, implies b continuant part of c at t & t is a temporal region & b and c are continuants)"@en ;
  skos:example "Centre of mass of a material entity continuant part of material entity at all times; continuant fiat external boundary of an object continuant part of object at all times."@en ;
  skos:prefLabel "continuant part of at all times"@en ;
.
