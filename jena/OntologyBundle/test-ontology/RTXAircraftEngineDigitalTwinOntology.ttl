  rdfs:label "Analysis Report" ;
  rdfs:subClassOf reo:Report ;
.
reo:AvionicsBay
  a owl:Class ;
  cco:definition "A Material Artifact that serves as a compartment within an aircraft designed to house electronic systems and instruments." ;
  rdfs:label "Avionics Bay" ;
  rdfs:subClassOf cco:Artifact ;
  owl:deprecated true ;
.
reo:Classification
  a owl:Class ;
  cco:definition "A Descriptive Information Content Entity that provides a systematic arrangement or grouping of entities based on shared characteristics." ;
  rdfs:label "Classification" ;
  rdfs:subClassOf cco:DescriptiveInformationContentEntity ;
.
reo:DegradedPerformanceStasis
  a owl:Class ;
