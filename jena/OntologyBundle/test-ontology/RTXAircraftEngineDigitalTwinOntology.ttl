  rdfs:label "Degraded Performance Stasis" ;
  rdfs:subClassOf cco:StasisOfFunction ;
.
reo:Delay
  a owl:Class ;
  cco:definition "A change causing a process to occur later than originally scheduled." ;
  rdfs:label "Delay" ;
