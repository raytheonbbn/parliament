  rdfs:range obo:BFO_0000020 ;
  owl:inverseOf obo:BFO_0000195 ;
  skos:altLabel "s-depended on by"@en ;
  skos:definition "b s-depended on by c =Def c specifically depends on b"@en ;
  skos:definition "b specifically depended on by c =Def c specifically depends on b"@en ;
  skos:example "Coloured object s-depended on by colour."@en ;
