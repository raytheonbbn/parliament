  skos:example "As for temporal part of."@en ;
  skos:prefLabel "proper temporal part of"@en ;
.
obo:BFO_0000137
  a owl:ObjectProperty ;
  a owl:TransitiveProperty ;
  dc:identifier "225-BFO" ;
  rdfs:domain obo:BFO_0000002 ;
  rdfs:label "proper continuant part of at all times"@en ;
