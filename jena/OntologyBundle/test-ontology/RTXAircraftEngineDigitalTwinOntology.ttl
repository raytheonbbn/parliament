[
  a owl:Class ;
  rdfs:subClassOf iof-core:CommercialServiceAgreement ;
  owl:intersectionOf (
      iof-core:Agreement
      [
        a owl:Restriction ;
        owl:onProperty iof-core:isAbout ;
        owl:someValuesFrom iof-core:CommercialService ;
      ]
      [
