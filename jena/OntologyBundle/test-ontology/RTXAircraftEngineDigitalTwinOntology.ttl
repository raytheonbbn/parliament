reos:BaselineSpecification
  a owl:Class ;
  obo:IAO_0000116 "There are 7 definitions of baseline in the standards covered by the IEEE sevocab database. The included definition seems most appropriate for SEBoK use. See http://www.computer.org/sevocab for more detail." ;
  cco:definition "A specification that has been formally reviewed and agreed upon, that thereafter serves as the basis for further development, and that can be changed only through formal change control procedures." ;
  cco:definition_source "ISO/IEEE. 2008. Systems and Software Engineering — Software Life Cycle Processes. Geneva, Switzerland: International Organization for Standards (ISO)/Institute of Electrical & Electronics Engineers (IEEE) Computer Society, ISO/IEEE 12207:2008(E)." ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology" ;
  rdfs:label "Baseline Specification" ;
  rdfs:subClassOf cco:DirectiveInformationContentEntity ;
.
reos:BuyerRole
  a owl:Class ;
  terms:creator "Mark Jensen"@en ;
  cco:definition "A Role that is realized in an Act of Purchasing wherein the bearer acts as agent and is responsible for selecting, administering, and obtaining products or raw materials for an Organization."@en ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology"^^xsd:anyURI ;
  rdfs:label "Buyer Role"@en ;
  rdfs:subClassOf obo:BFO_0000023 ;
.
reos:CancellationPlan
  a owl:Class ;
  cco:definition "A plan in which an agent prescribes the performance of an act that prevents a planned process from occurring"@en ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology"^^xsd:anyURI ;
  rdfs:label "Cancellation Plan"@en ;
  rdfs:subClassOf cco:PlanSpecification ;
.
reos:Capability
  a owl:Class ;
  cco:definition "(1) The ability to achieve a desired effect under specified (performance) standards and conditions through combinations of ways and means (activities and resources) to perform a set of activities." ;
  cco:definition "(2) The ability to execute a specified course of action. It is defined by a user and expressed in non-equipment based operational terms." ;
  cco:definition "(3) The ability to execute a specified course of action. A capability may or may not be accompanied by an intention." ;
  cco:definition_source "(1) DoD. 2009. DoD Architecture Framework (DoDAF), version 2.0. Washington, DC, USA: U.S. Department of Defense (DoD)." ;
  cco:definition_source "(2) MOD. 2004. Ministry of Defence Architecture Framework (MODAF), version 2. London, UK: U.K. Ministry of Defence." ;
  cco:definition_source "(3) DoD. 2009. Department of Defense Dictionary of Military and Associated Terms. Washington, DC, USA: U.S. Department of Defense (DoD), Joint Publication 1-02, 17 March 2009." ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology" ;
  rdfs:label "Capability" ;
  rdfs:subClassOf obo:BFO_0000016 ;
  owl:deprecated true ;
.
reos:CustomerRole
  a owl:Class ;
  terms:creator "William Mandrick"@en ;
  cco:definition "A role that is realized in the purchase of an artifact, commodity, or service"@en ;
  cco:definition_source "https://www.merriam-webster.com/dictionary/customer"^^xsd:anyURI ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology"^^xsd:anyURI ;
  rdfs:label "Customer Role"@en ;
  rdfs:subClassOf obo:BFO_0000023 ;
.
reos:DigitalThread
  a owl:Class ;
  cco:definition "the use of digital tools and representations for design, evaluation, and life cycle management." ;
  cco:definition_source "USAF Global Science and Technology Vision, Task Force. \"Global Horizons Final Report\". Homeland Security Digital Library. Archived from the original on 2021-09-30. Retrieved 2022-06-06." ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology" ;
  rdfs:label "Digital Thread" ;
  rdfs:subClassOf obo:BFO_0000015 ;
.
reos:DigitalTwin
  a owl:Class ;
  cco:definition "A Representational Information Content Entity that represents a System with a fidelity high enough that allows it to be used to emulate that system." ;
  cco:definition "A high-fidelity model of the system, which can be used to emulate the actual system." ;
  cco:definition_source "SEBoK original" ;
  cco:definition_source "https://sebokwiki.org/wiki/Digital_Twin_(glossary)" ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology" ;
  rdfs:label "Digital Twin" ;
  rdfs:subClassOf cco:RepresentationalInformationContentEntity ;
.
reos:EndItemRole
  a owl:Class ;
  terms:creator "Alexander Cox"@en ;
  cco:definition "A Role that inheres in an Artifact in virtue of it being the intended output of an Act of Artifact Processing such that the Artifact satisfies the Objective of that process."@en ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology"^^xsd:anyURI ;
  rdfs:comment "What counts as an End Item depends on the goals and interests of an Agent or Group of Agents."@en ;
  rdfs:label "End Item Role"@en ;
  rdfs:subClassOf obo:BFO_0000023 ;
  rdfs:subClassOf [
      a owl:Restriction ;
      owl:onProperty obo:RO_0000052 ;
      owl:someValuesFrom cco:Artifact ;
    ] ;
.
reos:EngineeredSystem
  a owl:Class ;
  cco:definition "(1) An open, concrete system of technical or socio-technical elements which is the focus of a SE life cycle . Its characteristics include being created by and for people, having a purpose and satisfying key stakeholders’ value propositions when considered as part of a broader system context ." ;
  cco:definition "(2) An engineered system is a system designed or adapted to interact with an anticipated operational environment to achieve one or more intended purposes while complying with applicable constraints." ;
  cco:definition_source "(1) This definition was created for SEBoK v. 1.0." ;
  cco:definition_source "(2) INCOSE Fellows Briefing to INCOSE Board of Directors, January 2019." ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology" ;
  rdfs:label "Engineered System" ;
  rdfs:subClassOf reos:System ;
  owl:deprecated true ;
.
reos:LifeCycle
  a owl:Class ;
  cco:definition "a series of stages through which something (such as an individual, culture, or manufactured product) passes during its lifetime" ;
  cco:definition_source "https://www.merriam-webster.com/dictionary/life%20cycle" ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology" ;
  rdfs:label "Life Cycle" ;
  rdfs:subClassOf obo:BFO_0000015 ;
.
reos:LineReplaceableUnitRole
  a owl:Class ;
  terms:creator "Alexander Cox"@en ;
  cco:alternative_label "LRU Role"@en ;
  cco:definition "A Component Role that inheres in an Artifact in virtue of being designed to be quickly replaced within a larger system."@en ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology"^^xsd:anyURI ;
  rdfs:label "Line Replaceable Unit Role"@en ;
  rdfs:subClassOf iof-core:MaterialComponentRole ;
  rdfs:subClassOf [
      a owl:Restriction ;
      owl:onProperty obo:RO_0000052 ;
      owl:someValuesFrom cco:Artifact ;
    ] ;
.
reos:ManagerRole
  a owl:Class ;
  terms:creator "Mark Jensen"@en ;
  cco:definition "An Organization Member Role that inheres in an Agent in virtue of a their assigned duties to oversee all or part of an organization's activities."@en ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology"^^xsd:anyURI ;
  rdfs:label "Manager Role"@en ;
  rdfs:subClassOf cco:OrganizationMemberRole ;
.
reos:MeasuringProcedureSpecification
  a owl:Class ;
  cco:definition "A Directive Information Content Entity that prescribes a Telemetry Process that produces a Measurement about some Entity."@en ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology" ;
  rdfs:label "Measuring Procedure Specification"@en ;
  rdfs:seeAlso "https://ontologyhub.rtx.com/ontologies/engine-dphm/flight-data#MeasuringProcedure"@en ;
  rdfs:subClassOf cco:PlanSpecification ;
.
reos:Mission
  a owl:Class ;
  terms:creator "Ron Rudnicki"@en ;
  cco:definition "A planned Act that has been assigned to one or more agents by a recognized authority"@en ;
  cco:elucidation "This term is is based upon the second sense of \"mission\" as stated in JP 1-02 Department of Defense Dictionary of Military and Associated dcterms: \"In common usage, especially when applied to lower military units, a duty assigned to an individual or unit; a task.\". The restatement is intended to allow for the use of the term to describe actions taking place within organizational contexts that are not military. The point of including the assignment by a recognized authority is to limit the scope of what is tagged by this term to directed actions within some organizational hierarchy."@en ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology"^^xsd:anyURI ;
  rdfs:label "Mission"@en ;
  rdfs:subClassOf cco:IntentionalAct ;
.
reos:NaturalSystem
  a owl:Class ;
  cco:definition "An open system whose elements, boundary, and relationships exist independently of human control." ;
  cco:definition_source "https://sebokwiki.org/wiki/Natural_System_(glossary)" ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology" ;
  rdfs:label "Natural System" ;
  rdfs:subClassOf iof-core:System ;
.
reos:OperationalEnvironment
  a owl:Class ;
  cco:definition "The environment in which systems are deployed." ;
  cco:definition_source "https://sebokwiki.org/wiki/Operational_Environment_(glossary)" ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology" ;
  rdfs:label "Operational Environment" ;
  rdfs:subClassOf obo:BFO_0000027 ;
.
reos:PlannedProcess
  a owl:Class ;
  dc:creator "Ron Rudnicki"@en ;
  cco:definition "A process that is prescribed by some plan"@en ;
  cco:elucidation "All planned acts are planned processes but not all planned processes are planned acts (e.g. planned but not performed)"@en ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology"^^xsd:anyURI ;
  rdfs:label "Planned Process"@en ;
  rdfs:subClassOf obo:BFO_0000015 ;
  owl:deprecated true ;
.
reos:PressureMeasurement
  a owl:Class ;
  terms:creator "Alexander Cox"@en ;
  cco:definition "A Ratio Measurement Information Content Entity that is a measurement of the Pressure of some entity."@en ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology"^^xsd:anyURI ;
  rdfs:comment "Since pressure can be measured using a ratio, ordinal, or nominal, this is a defined class provided to conveniently group terms for pressure measurements."@en ;
  rdfs:label "Pressure Measurement"@en ;
  rdfs:subClassOf cco:RatioMeasurementInformationContentEntity ;
  owl:equivalentClass [
      a owl:Class ;
      owl:intersectionOf (
          cco:RatioMeasurementInformationContentEntity
          [
            a owl:Restriction ;
            owl:onProperty cco:describes ;
            owl:someValuesFrom cco:Pressure ;
          ]
        ) ;
    ] ;
.
reos:ProductLifeCycle
  a owl:Class ;
  cco:definition "The evolution of a product from conception through retirement." ;
  cco:definition_source "https://sebokwiki.org/wiki/Life_Cycle_(glossary)" ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology" ;
  rdfs:label "Product Life Cycle" ;
  rdfs:subClassOf reos:LifeCycle ;
.
reos:ProductRole
  a owl:Class ;
  terms:creator "Alexander Cox"@en ;
  cco:definition "A Role that inheres in an Artifact in virtue of it being produced for the purpose of being sold by its producer."@en ;
  cco:is_curated_in_ontology "https://ontologyhub.rtx.com/RTXEnterpriseOntologies/RTXEnterpriseCoreOntology"^^xsd:anyURI ;
