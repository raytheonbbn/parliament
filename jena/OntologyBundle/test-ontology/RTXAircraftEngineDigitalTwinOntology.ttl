  rdfs:label "Event Description" ;
  rdfs:subClassOf cco:DescriptiveInformationContentEntity ;
.
reo:Failure
  a owl:Class ;
  cco:definition "An Event in which an entity loses its ability to perform a required function." ;
  cco:definition_source """SAE ARP926C - Fault/Failure Analysis Procedure
SAE ARP1834B - Fault/Failure Analysis For Digital Systems and Equipment
SAE ARP4761A (2023) - Guidelines for Conducting the Safety Assessment Process on Civil Aircraft, Systems, and Equipment""" ;
  rdfs:label "Failure" ;
  rdfs:subClassOf iof-core:Event ;
.
reo:FailureClassification
  a owl:Class ;
  cco:definition "A Classification that categorizes failure events into predefined classes based on shared characteristics." ;
  rdfs:label "Failure Classification" ;
  rdfs:subClassOf reo:Classification ;
.
reo:FailureDescription
  a owl:Class ;
  cco:definition "An Event Description that provides information about the characteristics or context of a failure event (the loss of ability to perform)." ;
  rdfs:label "Failure Description" ;
  rdfs:subClassOf reo:EventDescription ;
  iof-av:explanatoryNote "Failure Description documents the occurrence of a failure, capturing relevant information for analysis and reporting." ;
.
reo:FailureRate
  a owl:Class ;
  cco:definition "A ratio measurement information content entity representing the rate at which failures occur over time." ;
  rdfs:label "Failure Rate" ;
  rdfs:subClassOf cco:RatioMeasurementInformationContentEntity ;
.
reo:Fault
  a owl:Class ;
  cco:definition "Fault is a Stasis of Specifically Dependent Continuant representing the state of an entity being unable to perform as required due to an internal state." ;
  cco:definition_source """SAE ARP926C - Fault/Failure Analysis Procedure
SAE ARP1834B - Fault/Failure Analysis For Digital Systems and Equipment""" ;
  rdfs:label "Fault" ;
  rdfs:subClassOf cco:StasisOfSpecificallyDependentContinuant ;
.
reo:FaultClassification
  a owl:Class ;
  cco:definition "A Classification that categorizes faults based on their nature, causes, or effects." ;
  rdfs:label "Fault Classification" ;
  rdfs:subClassOf reo:Classification ;
.
reo:FaultCode
  a owl:Class ;
